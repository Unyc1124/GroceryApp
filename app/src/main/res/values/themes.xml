<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FreshBasket" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/brand_green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="bottomNavigationStyle">@style/Widget.FreshBasket.BottomNav</item>
    </style>

    <style name="Theme.FreshBasket.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_green</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_basket_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.FreshBasket</item>
    </style>

    <style name="Widget.FreshBasket.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_selector</item>
        <item name="itemTextColor">@color/bottom_nav_selector</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.FreshBasket.BottomNav.Indicator</item>
    </style>

    <style name="Widget.FreshBasket.BottomNav.Indicator" parent="@style/Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/brand_green_light</item>
    </style>

    <!-- Card Style -->
    <style name="Card.FreshBasket" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Button Primary -->
    <style name="Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Button Outlined -->
    <style name="Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_green</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/brand_green</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- TextInput -->
    <style name="TextInput.FreshBasket" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/brand_green</item>
        <item name="boxStrokeWidth">1.5dp</item>
    </style>

    <!-- OTP Input -->
    <style name="OtpInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_green</item>
        <item name="boxStrokeWidth">2dp</item>
    </style>
</resources>
